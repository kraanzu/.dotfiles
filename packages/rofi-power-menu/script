#!/usr/bin/env bash
ICON_DIR="${ICON_DIR:-$(dirname "$0")/../share/rofi-power-menu/icons}"

poweroff_option="Power Off"
reboot_option="Reboot"
windows_option="Reboot to Windows"

case "$ROFI_RETV" in
    0)
        if [ -z "$ROFI_DATA" ]; then
            printf '\0prompt\x1fPower Menu\n'
            printf '%s\0icon\x1f%s/power.png\n' "$poweroff_option" "$ICON_DIR"
            printf '%s\0icon\x1f%s/reboot.png\n' "$reboot_option" "$ICON_DIR"
            printf '%s\0icon\x1f%s/windows.png\n' "$windows_option" "$ICON_DIR"
        fi
        ;;
    1)
        case "$ROFI_DATA" in
            "confirm-poweroff")
                [ "$1" = "Yes" ] && systemctl poweroff
                exit 0
                ;;
            "confirm-reboot")
                [ "$1" = "Yes" ] && systemctl reboot
                exit 0
                ;;
            "confirm-windows")
                [ "$1" = "Yes" ] && sudo /run/current-system/sw/bin/grub-reboot "Windows Boot Manager (on /dev/nvme1n1p1)" && systemctl reboot
                exit 0
                ;;
            *)
                case "$1" in
                    "$poweroff_option")
                        printf '\0prompt\x1fConfirm power off?\n'
                        printf '\0data\x1fconfirm-poweroff\n'
                        printf 'Yes\0icon\x1f%s/yes.png\n' "$ICON_DIR"
                        printf 'No\0icon\x1f%s/no.png\n' "$ICON_DIR"
                        ;;
                    "$reboot_option")
                        printf '\0prompt\x1fConfirm reboot?\n'
                        printf '\0data\x1fconfirm-reboot\n'
                        printf 'Yes\0icon\x1f%s/yes.png\n' "$ICON_DIR"
                        printf 'No\0icon\x1f%s/no.png\n' "$ICON_DIR"
                        ;;
                    "$windows_option")
                        printf '\0prompt\x1fConfirm reboot to Windows?\n'
                        printf '\0data\x1fconfirm-windows\n'
                        printf 'Yes\0icon\x1f%s/yes.png\n' "$ICON_DIR"
                        printf 'No\0icon\x1f%s/no.png\n' "$ICON_DIR"
                        ;;
                esac
                ;;
        esac
        ;;
esac
