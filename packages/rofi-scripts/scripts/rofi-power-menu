#!/usr/bin/env bash

poweroff_option="Power Off"
reboot_option="Reboot"
windows_option="Reboot to Windows"

case "$ROFI_RETV" in
    0)
        if [ -z "$ROFI_DATA" ]; then
            printf '\0prompt\x1fPower Menu\n'
            printf '%s\n' "$poweroff_option"
            printf '%s\n' "$reboot_option"
            printf '%s\n' "$windows_option"
        fi
        ;;
    1)
        case "$ROFI_DATA" in
            "confirm-poweroff")
                [ "$1" = "Yes" ] && systemctl poweroff
                exit 0
                ;;
            "confirm-reboot")
                [ "$1" = "Yes" ] && systemctl reboot
                exit 0
                ;;
            "confirm-windows")
                [ "$1" = "Yes" ] && sudo /run/current-system/sw/bin/grub-reboot 2 && systemctl reboot
                exit 0
                ;;
            *)
                case "$1" in
                    "$poweroff_option")
                        printf '\0prompt\x1fConfirm power off?\n'
                        printf '\0data\x1fconfirm-poweroff\n'
                        printf 'Yes\n'
                        printf 'No\n'
                        ;;
                    "$reboot_option")
                        printf '\0prompt\x1fConfirm reboot?\n'
                        printf '\0data\x1fconfirm-reboot\n'
                        printf 'Yes\n'
                        printf 'No\n'
                        ;;
                    "$windows_option")
                        printf '\0prompt\x1fConfirm reboot to Windows?\n'
                        printf '\0data\x1fconfirm-windows\n'
                        printf 'Yes\n'
                        printf 'No\n'
                        ;;
                esac
                ;;
        esac
        ;;
esac
